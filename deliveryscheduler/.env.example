# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5432/deliveryscheduler?sslmode=disable

# Nats address
NATS_ADDR=nats://nats:4222

# Log level: debug | info | warn | error
LOG_LEVEL=info

OTEL_ENABLED=true

# OpenTelemetry Collector OTLP gRPC endpoint
OTEL_ENDPOINT=otel-collector:4317

OTEL_SERVICE_NAME=deliveryscheduler

# Max scheduled notifications dispatched per poll
POLL_BATCH_SIZE=100

# How often to poll for due notifications when idle (Go duration: 1s, 5s, 1m)
POLL_INTERVAL=5s
