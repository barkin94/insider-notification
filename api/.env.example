# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5432/api?sslmode=disable

# Nats address
NATS_ADDR=nats://nats:4222

# HTTP listen port
PORT=8080

# Log level: debug | info | warn | error
LOG_LEVEL=info

OTEL_ENABLED=true

# OpenTelemetry Collector OTLP gRPC endpoint
OTEL_ENDPOINT=otel-collector:4317

OTEL_SERVICE_NAME=api

# How often the scheduler polls for due scheduled notifications
SCHEDULER_INTERVAL=5s