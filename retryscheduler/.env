# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5432/retryscheduler?sslmode=disable

# Redis address (host:port)
REDIS_ADDR=redis:6379

# Log level: debug | info | warn | error
LOG_LEVEL=debug

OTEL_ENABLED=true

# OpenTelemetry Collector OTLP gRPC endpoint
OTEL_ENDPOINT=otel-collector:4317

OTEL_SERVICE_NAME=retryscheduler

# How often the dispatcher polls for due retries
RETRY_DISPATCH_INTERVAL=1s

# Max retries re-enqueued per tick
RETRY_DISPATCH_BATCH_SIZE=100
