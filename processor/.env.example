# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5432/processor?sslmode=disable

# Redis address (host:port)
REDIS_ADDR=redis:6379

# Number of concurrent delivery workers
WORKER_CONCURRENCY=10

# Log level: debug | info | warn | error
LOG_LEVEL=info

OTEL_ENABLED=true

# OpenTelemetry Collector OTLP gRPC endpoint
OTEL_ENDPOINT=otel-collector:4317

OTEL_SERVICE_NAME=processor

NTFN_DELIVERY_CLIENT_URL=http://mock-ntfn-provider:3001
NTFN_DELIVERY_CLIENT_TIMEOUT=10s

# How often the scheduler polls for due notifications and retries
SCHEDULER_INTERVAL=5s

# Weighted round-robin share for each priority lane (relative, not percentage)
HIGH_WEIGHT=3
NORMAL_WEIGHT=2
LOW_WEIGHT=1
