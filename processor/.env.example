# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/notifications?sslmode=disable

# Redis address (host:port)
REDIS_ADDR=localhost:6379

# Prometheus metrics listen port
PROCESSOR_METRICS_PORT=8081

# Number of concurrent delivery workers
WORKER_CONCURRENCY=10

# Log level: debug | info | warn | error
LOG_LEVEL=info

# OpenTelemetry Collector OTLP gRPC endpoint
OTEL_ENDPOINT=otel-collector:4317

# Webhook delivery target (get a free UUID at https://webhook.site)
WEBHOOK_URL=https://webhook.site/<your-uuid>
