# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5432/notifications?sslmode=disable&search_path=processor,public

# Redis address (host:port)
REDIS_ADDR=redis:6379

# Number of concurrent delivery workers
WORKER_CONCURRENCY=10

# Log level: debug | info | warn | error
LOG_LEVEL=info

# OpenTelemetry Collector OTLP gRPC endpoint
OTEL_ENDPOINT=otel-collector:4317

OTEL_SERVICE_NAME=processor

# Webhook delivery target (get a free UUID at https://webhook.site)
WEBHOOK_URL=https://webhook.site/d4e8d4a5-22a5-419e-aa8d-c66e0eec0a93
